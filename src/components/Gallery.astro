---
import { Image } from 'astro:assets';
import { photos } from '../data/photos';

const years = [...new Set(photos.map((p) => p.date.slice(0, 4)))].sort((a, b) => b.localeCompare(a));

const groupedByYear = years.reduce(
  (acc, year) => {
    acc[year] = photos.filter((p) => p.date.startsWith(year));
    return acc;
  },
  {} as Record<string, typeof photos>,
);
---

{years.map((year) => (
  <section class="category-section" data-year={year}>
    <div class="container">
      <h2>{year}</h2>
      <div class="masonry">
        {groupedByYear[year].map((photo) => (
          <figure data-full-src={photo.src.src} data-category={photo.category} data-alt={photo.alt} data-date={photo.date}>
            <Image
              src={photo.src}
              alt={photo.alt}
              widths={[400, 800, 1200]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    </div>
  </section>
))}
