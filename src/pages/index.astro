---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import FilterChips from '../components/FilterChips.astro';
import Gallery from '../components/Gallery.astro';
import Lightbox from '../components/Lightbox.astro';
import headshot from '../assets/photos/headshot.jpg';
---

<Layout>
  <header class="site-header container" style="position: relative;">
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
      </svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
      </svg>
    </button>
    <div class="header-identity">
      <Image src={headshot} alt="Benjamin Leeds" class="avatar" width={80} height={80} />
      <h1>Benjamin Leeds</h1>
    </div>
    <p>I just enjoy taking pictures. Mostly of my family, but sometimes of creation.</p>
  </header>

  <div class="container">
    <FilterChips />
  </div>

  <Gallery />
  <Lightbox />

  <footer class="site-footer container">
    <p>&copy; {new Date().getFullYear()} Benjamin Leeds</p>
  </footer>
</Layout>

<script>
  // Filter chip logic
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const sections = document.querySelectorAll<HTMLElement>('.category-section');
  const figures = document.querySelectorAll<HTMLElement>('.masonry figure');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('active'));
      chip.classList.add('active');

      const filter = chip.dataset.filter;

      // Show/hide individual figures by category
      figures.forEach((fig) => {
        if (filter === 'all' || fig.dataset.category === filter) {
          fig.classList.remove('hidden-photo');
        } else {
          fig.classList.add('hidden-photo');
        }
      });

      // Hide year sections that have no visible photos
      sections.forEach((section) => {
        const visiblePhotos = section.querySelectorAll('figure:not(.hidden-photo)');
        if (visiblePhotos.length === 0) {
          section.classList.add('hidden');
        } else {
          section.classList.remove('hidden');
        }
      });
    });
  });

  // Fade-in on load via IntersectionObserver
  const images = document.querySelectorAll<HTMLImageElement>('.masonry img');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const img = entry.target as HTMLImageElement;
          if (img.complete) {
            img.classList.add('loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
          }
          observer.unobserve(img);
        }
      });
    },
    { rootMargin: '50px' },
  );

  images.forEach((img) => observer.observe(img));

  // Dark mode toggle
  const themeToggle = document.getElementById('theme-toggle')!;
  themeToggle.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
